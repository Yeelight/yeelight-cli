{
  "mcpServers": {
    "yeelight-cloud": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://api.yeelight.com/apis/mcp_server/v1/mcp",
        "--header",
        "Authorization:${YEELIGHT_AUTHORIZATION}",
        "--header",
        "House-Id:${YEELIGHT_HOUSE_ID}",
        "--header",
        "Yeelight-Region:${YEELIGHT_REGION}",
        "--header",
        "bizType:${YEELIGHT_BIZ_TYPE}"
      ],
      "env": {
        "YEELIGHT_AUTHORIZATION": "${YEELIGHT_AUTHORIZATION}",
        "YEELIGHT_HOUSE_ID": "${YEELIGHT_HOUSE_ID}",
        "YEELIGHT_REGION": "${YEELIGHT_REGION}",
        "YEELIGHT_BIZ_TYPE": "${YEELIGHT_BIZ_TYPE}"
      }
    },
    "yeelight-metadata": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://api.yeelight.com/apis/metadata_mcp_server/v1/mcp",
        "--header",
        "Authorization:${YEELIGHT_AUTHORIZATION}",
        "--header",
        "House-Id:${YEELIGHT_HOUSE_ID}",
        "--header",
        "Yeelight-Region:${YEELIGHT_REGION}",
        "--header",
        "bizType:${YEELIGHT_BIZ_TYPE}"
      ],
      "env": {
        "YEELIGHT_AUTHORIZATION": "${YEELIGHT_AUTHORIZATION}",
        "YEELIGHT_HOUSE_ID": "${YEELIGHT_HOUSE_ID}",
        "YEELIGHT_REGION": "${YEELIGHT_REGION}",
        "YEELIGHT_BIZ_TYPE": "${YEELIGHT_BIZ_TYPE}"
      }
    }
  }
}
